# ──────────────────────────────────────────────────────────────
# Office – Beispiel-Umgebungsvariablen
# Kopiere diese Datei nach `.env` und passe die Werte an.
# ──────────────────────────────────────────────────────────────

# ── Datenbank (PostgreSQL) ─────────────────────────────────────
# Innerhalb des Docker-Netzwerks lautet der Host "postgres".
# Für lokale Ausführung (ohne Docker) "localhost" verwenden.
POSTGRES_USER=office
POSTGRES_PASSWORD=office_dev_pw
POSTGRES_DB=office
DATABASE_URL=postgresql://office:office_dev_pw@postgres:5432/office?schema=public

# ── Authentifizierung (JWT) ────────────────────────────────────
JWT_SECRET=change-me-in-production-please-use-a-long-random-string
JWT_EXPIRES_IN=8h

# ── Objektspeicher (MinIO / S3) ────────────────────────────────
# Host "minio" im Docker-Netzwerk, "localhost" bei lokaler Ausführung.
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=office_minio
MINIO_SECRET_KEY=office_minio_pw
MINIO_BUCKET=office-documents

# ── Frontend (Next.js) ─────────────────────────────────────────
# Öffentliche API-URL, die der Browser erreicht.
NEXT_PUBLIC_API_URL=http://localhost:3801/api

# ── CORS ──────────────────────────────────────────────────────
# Origin des Frontends (muss exakt mit der Browser-URL übereinstimmen).
# Lokal: http://localhost:3800, Docker-Dev: http://localhost:3900
WEB_ORIGIN=http://localhost:3800

# ── Ports (für docker-compose) ─────────────────────────────────
WEB_PORT=3800
API_PORT=3801

# ── Kiosk (optional) ─────────────────────────────────────────
# API-Key für den öffentlichen Kiosk-Endpoint (Projekt-Stempelstatus).
# In Produktion PFLICHT – ohne diesen Key ist der Kiosk-Endpoint gesperrt.
# KIOSK_API_KEY=ein-zufaelliger-api-key

# ── OCR-Service ──────────────────────────────────────────────
# URL zum selbst-gehosteten PaddleOCR-Microservice.
OCR_SERVICE_URL=http://ocr-service:8000

# ── Firmendaten (Rechnungen) ─────────────────────────────────
# In Produktion UNBEDINGT setzen, sonst erscheinen Muster-Daten auf PDFs!
# COMPANY_NAME=VivaHome GmbH
# COMPANY_ADDRESS=Musterstr. 1, 12345 Stadt
# COMPANY_PHONE=0123 456789
# COMPANY_EMAIL=info@vivahome.de
# COMPANY_TAX_NUMBER=DE000000000
# COMPANY_BANK_NAME=Bankname
# COMPANY_BANK_IBAN=DE00 0000 0000 0000 0000 00
# COMPANY_BANK_BIC=BANKDEFF

# ── Umgebung ─────────────────────────────────────────────────
# NODE_ENV=production (aktiviert Sicherheitsprüfungen)
NODE_ENV=development
