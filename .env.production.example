# ──────────────────────────────────────────────────────────────
# Office – Produktions-Umgebungsvariablen
# Kopiere diese Datei nach `.env.production` und trage echte Werte ein.
# .env.production ist in .gitignore — NIEMALS echte Secrets committen.
# ──────────────────────────────────────────────────────────────

NODE_ENV=production

# ── Datenbank (PostgreSQL) ─────────────────────────────────────
POSTGRES_USER=office
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=office
DATABASE_URL=postgresql://office:CHANGE_ME@postgres:5432/office?schema=public

# ── Authentifizierung (JWT) ────────────────────────────────────
# Lang, zufällig. z. B. `openssl rand -hex 48`
JWT_SECRET=CHANGE_ME_LONG_RANDOM_STRING
JWT_EXPIRES_IN=8h

# ── Objektspeicher (MinIO / S3) ────────────────────────────────
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=CHANGE_ME
MINIO_SECRET_KEY=CHANGE_ME
MINIO_BUCKET=office-documents

# ── Frontend (Next.js) ─────────────────────────────────────────
# Öffentliche API-URL, die der Browser erreicht.
NEXT_PUBLIC_API_URL=https://office.vivahome.de/api

# ── CORS ──────────────────────────────────────────────────────
# Origin des Frontends (muss exakt mit der Browser-URL übereinstimmen).
WEB_ORIGIN=https://office.vivahome.de
