{
  "name": "office",
  "version": "0.1.0",
  "private": true,
  "description": "Office – CRM, Projektverwaltung, Monteurverwaltung, Zeiterfassung",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:web": "pnpm --filter @office/web dev",
    "dev:api": "pnpm --filter @office/api dev",
    "build": "pnpm -r build",
    "build:web": "pnpm --filter @office/web build",
    "build:api": "pnpm --filter @office/api build",
    "lint": "pnpm -r lint",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:push": "prisma db push",
    "prisma:seed": "prisma db seed",
    "prisma:studio": "prisma studio"
  },
  "prisma": {
    "schema": "prisma/schema.prisma",
    "seed": "ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.16.10",
    "prisma": "^5.22.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "sharp": "^0.35.2"
  }
}
