{
  "expo": {
    "name": "VH Kiosk",
    "slug": "vh-kiosk",
    "scheme": "vhkiosk",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "platforms": [
      "android"
    ],
    "android": {
      "package": "de.vivahome.kiosk",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#030712"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Die App benötigt Zugriff auf die Kamera für Foto-Dokumentation."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Die App benötigt den Standort für die Zeiterfassung.",
          "locationWhenInUsePermission": "Die App benötigt den Standort für die Zeiterfassung."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Die App benötigt Zugriff auf Fotos für die Dokumentation.",
          "cameraPermission": "Die App benötigt Zugriff auf die Kamera für Foto-Dokumentation."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "efd3b7f3-974c-4cc8-8ee7-4936d856c030"
      }
    },
    "owner": "vivahome"
  }
}
